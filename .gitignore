# ── New layout: data / artifacts / archive ────────────────────────────
# Ignore heavy contents but keep directory structure (.gitkeep files).
/data/raw/*
/data/derived/*
/data/cache/*
!/data/raw/.gitkeep
!/data/derived/.gitkeep
!/data/cache/.gitkeep

/artifacts/checkpoints/**
/artifacts/runs/**
/artifacts/generated/**
/artifacts/analysis/**
/artifacts/debug/**
/artifacts/logs/**
!/artifacts/checkpoints/**/.gitkeep
!/artifacts/runs/.gitkeep
!/artifacts/generated/.gitkeep
!/artifacts/analysis/.gitkeep
!/artifacts/debug/.gitkeep
!/artifacts/logs/.gitkeep

/archive/legacy_outputs/*
!/archive/legacy_outputs/.gitkeep
# archive/legacy_code/ is tracked (source code)